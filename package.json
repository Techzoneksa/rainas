{
  "name": "raina",
  "version": "0.2.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-turbo-permissions.cjs",
    "dev": "turbo dev --parallel",
    "build": "node scripts/hostinger-build-web.cjs",
    "build:web": "pnpm --filter @raina/web build",
    "build:all": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"*.{json,md,yml,yaml}\" \".prettierrc\" \".github/**/*.{yml,yaml}\" \"apps/**/*.{ts,tsx,js,mjs,css,json}\" \"docs/**/*.md\" \"packages/**/*.{ts,tsx,js,mjs,css,json,md}\" \"scripts/**/*.{js,mjs}\"",
    "format:check": "prettier --check \"*.{json,md,yml,yaml}\" \".prettierrc\" \".github/**/*.{yml,yaml}\" \"apps/**/*.{ts,tsx,js,mjs,css,json}\" \"docs/**/*.md\" \"packages/**/*.{ts,tsx,js,mjs,css,json,md}\" \"scripts/**/*.{js,mjs}\"",
    "smoke": "node scripts/smoke-foundation.mjs",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @raina/api db:generate",
    "db:migrate": "pnpm --filter @raina/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @raina/api db:migrate:deploy",
    "db:seed": "pnpm --filter @raina/api db:seed",
    "db:reset": "pnpm --filter @raina/api db:reset",
    "db:studio": "pnpm --filter @raina/api db:studio",
    "clean": "node scripts/clean.mjs"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.2",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "eslint": "10.4.1",
    "pnpm": "11.9.0",
    "prettier": "3.8.3",
    "turbo": "2.9.16",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8"
  }
}
