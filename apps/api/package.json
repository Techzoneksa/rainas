{
  "name": "@raina/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@nestjs/common": "11.1.26",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.26",
    "@nestjs/platform-express": "11.1.26",
    "@raina/shared-types": "workspace:*",
    "@raina/validation": "workspace:*",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "helmet": "8.2.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@nestjs/testing": "11.1.26",
    "@raina/eslint-config": "workspace:*",
    "@raina/typescript-config": "workspace:*",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.22.4",
    "vitest": "4.1.8"
  }
}
